# Neon: pooled connection for the app
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Neon: direct (non-pooler) for Prisma migrations — required when DATABASE_URL uses pooler
DIRECT_URL="postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/neondb?sslmode=require"

# 32-byte hex for encrypting secrets in SiteSettings (openssl rand -hex 32)
SETTINGS_ENCRYPTION_KEY=""

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
RESEND_API_KEY=""
ADMIN_EMAIL="info@vivabloomdecor.com.au"
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
# Unsigned upload preset name from Cloudinary → Settings → Upload → Upload presets
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="vivabloom_gallery"
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
